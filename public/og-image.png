<svg width="1200" height="630" viewBox="0 0 1200 630" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="og-bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#04111e" />
      <stop offset="50%" stop-color="#071526" />
      <stop offset="100%" stop-color="#050e1c" />
    </linearGradient>
    <linearGradient id="og-epi" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#3d8c28" />
      <stop offset="35%" stop-color="#7dbc48" />
      <stop offset="65%" stop-color="#5fa832" />
      <stop offset="100%" stop-color="#2d6a1a" />
    </linearGradient>
    <linearGradient id="og-leaf-ext" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#1a5218" />
      <stop offset="50%" stop-color="#2a7020" />
      <stop offset="100%" stop-color="#1a5218" />
    </linearGradient>
    <linearGradient id="og-leaf-int" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#1e5c1c" />
      <stop offset="50%" stop-color="#2e7a28" />
      <stop offset="100%" stop-color="#1e5c1c" />
    </linearGradient>
    <radialGradient id="og-sun" cx="40%" cy="38%">
      <stop offset="0%" stop-color="#ffe040" />
      <stop offset="55%" stop-color="#ffc020" />
      <stop offset="100%" stop-color="#f09000" />
    </radialGradient>
    <radialGradient id="og-glow" cx="50%" cy="50%">
      <stop offset="0%" stop-color="#10b981" stop-opacity="0.15" />
      <stop offset="100%" stop-color="#10b981" stop-opacity="0" />
    </radialGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="url(#og-bg)" />
  
  <!-- Decorative glow -->
  <circle cx="300" cy="315" r="400" fill="url(#og-glow)" />

  <!-- Logo (scaled and positioned) -->
  <g transform="translate(150, 215) scale(1)">
    <circle cx="100" cy="100" r="96" fill="white" />
    <ellipse cx="55" cy="115" rx="15" ry="56" transform="rotate(-38 55 115)" fill="url(#og-leaf-ext)" />
    <line x1="36" y1="68" x2="66" y2="155" stroke="#1a5218" stroke-width="1.2" opacity="0.55" />
    <ellipse cx="145" cy="115" rx="15" ry="56" transform="rotate(38 145 115)" fill="url(#og-leaf-ext)" />
    <line x1="164" y1="68" x2="134" y2="155" stroke="#1a5218" stroke-width="1.2" opacity="0.55" />
    <ellipse cx="76" cy="120" rx="11" ry="48" transform="rotate(-18 76 120)" fill="url(#og-leaf-int)" />
    <ellipse cx="124" cy="120" rx="11" ry="48" transform="rotate(18 124 120)" fill="url(#og-leaf-int)" />
    <ellipse cx="103" cy="110" rx="17" ry="55" fill="#2a6a15" opacity="0.35" />
    <ellipse cx="100" cy="108" rx="16" ry="54" fill="url(#og-epi)" />
    <ellipse cx="94" cy="98" rx="5.5" ry="30" fill="#a8d860" opacity="0.55" />
    <ellipse cx="100" cy="162" rx="26" ry="7" fill="#1e5c1c" opacity="0.6" />
    <circle cx="68" cy="60" r="15" fill="url(#og-sun)" />
    <circle cx="132" cy="60" r="15" fill="url(#og-sun)" />
    <circle cx="100" cy="84" r="7.5" fill="#cc1800" />
    <circle cx="100" cy="84" r="5" fill="#e62010" />
    <circle cx="100" cy="108" r="7.5" fill="#cc1800" />
    <circle cx="100" cy="108" r="5" fill="#e62010" />
    <circle cx="100" cy="132" r="7.5" fill="#cc1800" />
    <circle cx="100" cy="132" r="5" fill="#e62010" />
    <circle cx="100" cy="100" r="96" fill="none" stroke="#1a5218" stroke-width="3.5" />
  </g>

  <!-- Text content -->
  <text x="480" y="280" font-family="Georgia, serif" font-size="72" font-weight="700" fill="#ffffff">
    Binova
  </text>
  <text x="480" y="330" font-family="Georgia, serif" font-size="36" fill="rgba(16, 185, 129, 0.95)">
    Holding Group
  </text>
  <text x="480" y="400" font-family="Georgia, serif" font-size="28" font-style="italic" fill="rgba(16, 185, 129, 0.8)">
    A Passion for Excellence
  </text>
  
  <!-- Decorative line -->
  <line x1="480" y1="360" x2="750" y2="360" stroke="#10b981" stroke-width="2" opacity="0.3" />
</svg>
